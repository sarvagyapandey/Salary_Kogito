package org.acme.salary;

import org.acme.salary.SalaryFact;

// ============ BASIC SALARY RULES ============
rule "Basic Salary - CTC <= 13000"
    when
        $f: SalaryFact($ctc : ctc != null, $ctc <= 13000)
    then
        $f.setBasic($ctc * 0.4);
        modify($f) { }
end

rule "Basic Salary - CTC > 13000 && <= 25000"
    when
        $f: SalaryFact($ctc : ctc != null, $ctc > 13000, $ctc <= 25000)
    then
        $f.setBasic($ctc * 0.4);
        modify($f) { }
end

rule "Basic Salary - CTC > 25000 && <= 45000"
    when
        $f: SalaryFact($ctc : ctc != null, $ctc > 25000, $ctc <= 45000)
    then
        $f.setBasic($ctc * 0.4);
        modify($f) { }
end

rule "Basic Salary - CTC > 45000"
    when
        $f: SalaryFact($ctc : ctc != null, $ctc > 45000)
    then
        $f.setBasic($ctc * 0.4);
        modify($f) { }
end

// ============ HRA RULES ============
rule "HRA - CTC <= 45000"
    when
        $f: SalaryFact($ctc : ctc != null, $ctc <= 45000)
    then
        $f.setHra(0.0);
        modify($f) { }
end

rule "HRA - CTC > 45000"
    when
        $f: SalaryFact($ctc : ctc != null, $ctc > 45000, $basic : basic != null, $basic > 0)
    then
        $f.setHra($basic * 0.5);
        modify($f) { }
end

// ============ BONUS RULES ============
rule "Bonus - BasicStat <= 21000"
    when
        $f: SalaryFact($stat : basicStat != null, $stat <= 21000)
    then
        $f.setBonus($stat * 0.0833);
        modify($f) { }
end

rule "Bonus - BasicStat > 21000"
    when
        $f: SalaryFact($stat : basicStat != null, $stat > 21000)
    then
        $f.setBonus(0.0);
        modify($f) { }
end

// ============ EMPLOYEE PF RULES ============
rule "Employee PF - Option P1"
    when
        $f: SalaryFact($opt : pfOption == "P1", $basic : basic != null, $basic > 0)
    then
        $f.setEmployeePF($basic * 0.12);
        modify($f) { }
end

rule "Employee PF - Option P2"
    when
        $f: SalaryFact($opt : pfOption == "P2", $basic : basic != null, $basic > 0)
    then
        $f.setEmployeePF($basic * 0.10);
        modify($f) { }
end

rule "Employee PF - Option P3"
    when
        $f: SalaryFact($opt : pfOption == "P3", $basic : basic != null, $basic > 0)
    then
        $f.setEmployeePF($basic * 0.08);
        modify($f) { }
end

rule "Employee PF - Option P4"
    when
        $f: SalaryFact($opt : pfOption == "P4", $basic : basic != null, $basic > 0)
    then
        $f.setEmployeePF($basic * 0.06);
        modify($f) { }
end

rule "Employee PF - Option P5"
    when
        $f: SalaryFact(pfOption == "P5")
    then
        $f.setEmployeePF(0.0);
        modify($f) { }
end

// ============ EMPLOYER PF RULES ============
rule "Employer PF - Option P1"
    when
        $f: SalaryFact($opt : pfOption == "P1", $basic : basic != null, $basic > 0)
    then
        $f.setEmployerPF($basic * 0.12);
        modify($f) { }
end

rule "Employer PF - Option P2"
    when
        $f: SalaryFact($opt : pfOption == "P2", $basic : basic != null, $basic > 0)
    then
        $f.setEmployerPF($basic * 0.10);
        modify($f) { }
end

rule "Employer PF - Option P3"
    when
        $f: SalaryFact($opt : pfOption == "P3", $basic : basic != null, $basic > 0)
    then
        $f.setEmployerPF($basic * 0.08);
        modify($f) { }
end

rule "Employer PF - Option P4"
    when
        $f: SalaryFact($opt : pfOption == "P4", $basic : basic != null, $basic > 0)
    then
        $f.setEmployerPF($basic * 0.06);
        modify($f) { }
end

rule "Employer PF - Option P5"
    when
        $f: SalaryFact(pfOption == "P5")
    then
        $f.setEmployerPF(0.0);
        modify($f) { }
end

// ============ EMPLOYEE ESI RULES ============
rule "Employee ESI - BasicStat <= 21000"
    when
        $f: SalaryFact($stat : basicStat != null, $stat <= 21000)
    then
        $f.setEmployeeESI($stat * 0.0075);
        modify($f) { }
end

rule "Employee ESI - BasicStat > 21000"
    when
        $f: SalaryFact($stat : basicStat != null, $stat > 21000)
    then
        $f.setEmployeeESI(0.0);
        modify($f) { }
end

// ============ EMPLOYER ESI RULES ============
rule "Employer ESI - BasicStat <= 21000"
    when
        $f: SalaryFact($stat : basicStat != null, $stat <= 21000)
    then
        $f.setEmployerESI($stat * 0.0325);
        modify($f) { }
end

rule "Employer ESI - BasicStat > 21000"
    when
        $f: SalaryFact($stat : basicStat != null, $stat > 21000)
    then
        $f.setEmployerESI(0.0);
        modify($f) { }
end

// ============ MEDICAL INSURANCE RULES ============
rule "Medical Insurance - BasicStat >= 21001"
    when
        $f: SalaryFact($stat : basicStat != null, $stat >= 21001)
    then
        $f.setMedicalInsurance(250.0);
        modify($f) { }
end

rule "Medical Insurance - BasicStat < 21001"
    when
        $f: SalaryFact($stat : basicStat != null, $stat < 21001)
    then
        $f.setMedicalInsurance(0.0);
        modify($f) { }
end
